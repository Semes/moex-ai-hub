ENVIRONMENT=development

API_PORT=8000
FRONTEND_PORT=3000
DB_PORT=5432

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:${DB_PORT}/moex_ai_hub
CORS_ORIGINS=http://localhost:${FRONTEND_PORT}

KEYCLOAK_BASE_URL=https://keycloak.example.com
KEYCLOAK_REALM=moex
KEYCLOAK_CLIENT_ID=moex-ai-hub-api
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_INTROSPECTION_TIMEOUT=5.0

NEXT_PUBLIC_API_BASE_URL=http://localhost:${API_PORT}
